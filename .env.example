SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRY=86400
TOTP_ISSUER=VPS Panel
TOTP_ENCRYPTION_KEY=replace_with_32_byte_base64_key
PANEL_PORT=4000
PANEL_LOGIN_PORT=
PANEL_UPDATE_WEBHOOK_SECRET=
PANEL_UPDATE_REPO_FULL_NAME=
PANEL_UPDATE_BRANCH=main
PANEL_UPDATE_WORKDIR=/opt/vps-panel
PANEL_UPDATE_SCRIPT=/opt/vps-panel/scripts/deploy/update-panel.sh
PANEL_UPDATE_STATUS_FILE=/var/log/vps-panel/self-update-status.json
PANEL_UPDATE_LOG_FILE=/var/log/vps-panel/self-update.log
PANEL_UPDATE_DIRTY_STRATEGY=fail
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://panel_user:panel_pass@localhost:6432/panel_main
DIRECT_DATABASE_URL=postgresql://panel_user:panel_pass@localhost:5432/panel_main
REDIS_URL=redis://localhost:6379
SYSAGENT_URL=http://127.0.0.1:5000
MAIL_SERVICE_URL=http://127.0.0.1:5100
VPS_IP=127.0.0.1
FILE_MANAGER_ROOT=/var/www
ALLOW_LIVE_SYSTEM_COMMANDS=false
