generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum DomainStatus {
  ACTIVE
  PENDING
  SUSPENDED
}

enum DomainHostingMode {
  PUBLIC_HTML
  DEPLOYMENT_PROXY
  REDIRECT
}

enum DnsRecordType {
  A
  AAAA
  CNAME
  MX
  TXT
  NS
  SRV
  CAA
}

enum MailFolder {
  INBOX
  SENT
  DRAFTS
  SPAM
  TRASH
}

enum DeploymentFramework {
  LARAVEL
  NEXTJS
  NODEJS
  PYTHON
  GO
  STATIC
}

enum DeploymentStatus {
  QUEUED
  RUNNING
  STOPPED
  DEPLOYING
  BUILDING
  FAILED
}

enum DatabaseType {
  POSTGRESQL
  MYSQL
}

enum DeploymentSourceProvider {
  MANUAL
  GIT_URL
  GITHUB
  FILE_MANAGER
  UPLOAD
}

enum DeploymentRuntime {
  NODE
  PHP
  PYTHON
  GO
  STATIC
}

enum DeploymentPackageManager {
  NPM
  PNPM
  YARN
  COMPOSER
  PIP
  UV
  GO
  NONE
}

enum DeploymentProcessManager {
  PM2
  SUPERVISOR
  SYSTEMD
  STATIC
  NONE
}

enum DeploymentHealthStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  DOWN
}

enum DeploymentReleaseStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  ROLLED_BACK
}

enum DeploymentStep {
  QUEUED
  PREFLIGHT
  CLONING
  INSTALLING
  MIGRATING
  BUILDING
  CONFIGURING_PROXY
  STARTING
  HEALTH_CHECK
  SUCCEEDED
  FAILED
  ROLLBACK
}

enum DeploymentDoctorApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  FAILED
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
}

enum FirewallAction {
  ALLOW
  DENY
  LIMIT
}

enum FirewallDirection {
  IN
  OUT
}

enum SecretKind {
  GITHUB_TOKEN
  DEPLOYMENT_ENV
  DATABASE_PASSWORD
  DATABASE_URL
  MAIL_PASSWORD
  WEBHOOK_SECRET
  GENERIC
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  DEPLOY
  START
  STOP
  RESTART
  ROLLBACK
  APPLY
  LOGIN
  LOGOUT
}

enum GuardianSeverity {
  INFO
  WARNING
  CRITICAL
}

enum GuardianIncidentStatus {
  OPEN
  RESOLVED
}

enum GuardianActionStatus {
  SKIPPED
  SUCCEEDED
  FAILED
}

enum GuardianBlockStatus {
  ACTIVE
  EXPIRED
  REMOVED
}

enum GuardianFileFindingStatus {
  OPEN
  TRUSTED
  RESOLVED
}

enum WhmMigrationStatus {
  DRAFT
  CONNECTED
  SCANNING
  SCANNED
  IMPORTING
  IMPORTED
  MIGRATING
  COMPLETED
  FAILED
}

enum WhmMigrationItemType {
  ACCOUNT
  DOMAIN
  DNS_ZONE
  DNS_RECORD
  PACKAGE
  MAILBOX
  DATABASE
  SSL
  FILES
}

enum WhmMigrationItemStatus {
  DISCOVERED
  MAPPED
  IMPORTED
  APPROVED
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum WhmMigrationTaskType {
  FILE_SYNC
  DATABASE_DUMP
  MAIL_SYNC
  DNS_CUTOVER
  ROLLBACK
}

enum PanelBackupStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

model Domain {
  id           String        @id @default(cuid())
  name         String        @unique
  status       DomainStatus  @default(PENDING)
  hostingMode  DomainHostingMode @default(PUBLIC_HTML) @map("hosting_mode")
  documentRoot String        @default("public_html") @map("document_root")
  redirectUrl  String?       @map("redirect_url")
  hostingDeploymentId String? @map("hosting_deployment_id")
  accountId    String?       @map("account_id")
  sslEnabled   Boolean       @default(false) @map("ssl_enabled")
  sslExpiry    DateTime?     @map("ssl_expiry")
  forceSsl     Boolean       @default(true) @map("force_ssl")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  subdomains   Subdomain[]
  dnsRecords   DnsRecord[]
  mailAccounts MailAccount[]
  deployments  Deployment[]
  deploymentBindings DeploymentDomain[]
  account      Account?      @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([name])
  @@map("domains")
}

model Account {
  id           String        @id @default(cuid())
  username     String        @unique
  email        String?       @unique
  ownerName    String?       @map("owner_name")
  passwordHash String        @map("password_hash")
  status       AccountStatus @default(ACTIVE)
  packageId    String?       @map("package_id")
  homeRoot     String        @map("home_root")
  packageName  String?       @map("package_name")
  diskLimitMb  Int?          @map("disk_limit_mb")
  domainLimit  Int?          @map("domain_limit")
  mailboxLimit Int?          @map("mailbox_limit")
  databaseLimit Int?         @map("database_limit")
  deploymentLimit Int?       @map("deployment_limit")
  metadata     Json          @default("{}")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  package      AccountPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  domains      Domain[]
  deployments  Deployment[]
  mailAccounts MailAccount[]
  databases    AccountDatabase[]

  @@index([status, createdAt])
  @@index([packageId])
  @@map("accounts")
}

model AccountPackage {
  id              String    @id @default(cuid())
  name            String    @unique
  description     String?
  diskLimitMb     Int?      @map("disk_limit_mb")
  domainLimit     Int?      @map("domain_limit")
  mailboxLimit    Int?      @map("mailbox_limit")
  databaseLimit   Int?      @map("database_limit")
  deploymentLimit Int?      @map("deployment_limit")
  isDefault       Boolean   @default(false) @map("is_default")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  accounts        Account[]

  @@index([isDefault, name])
  @@map("account_packages")
}

model AccountDatabase {
  id        String       @id @default(cuid())
  accountId String       @map("account_id")
  engine    DatabaseType
  database  String
  username  String
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  account   Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([engine, database])
  @@index([accountId, engine])
  @@map("account_databases")
}

model Subdomain {
  id         String  @id @default(cuid())
  domainId   String  @map("domain_id")
  name       String
  target     String
  sslEnabled Boolean @default(false) @map("ssl_enabled")
  domain     Domain  @relation(fields: [domainId], references: [id], onDelete: Cascade)
  deploymentBindings DeploymentDomain[]

  @@unique([domainId, name])
  @@map("subdomains")
}

model DnsRecord {
  id        String        @id @default(cuid())
  domainId  String        @map("domain_id")
  type      DnsRecordType
  name      String
  value     String
  ttl       Int           @default(3600)
  priority  Int?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  domain    Domain        @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId, type])
  @@map("dns_records")
}

model NameServer {
  id        String   @id @default(cuid())
  hostname  String   @unique
  ipv4      String?  @map("ipv4")
  ipv6      String?  @map("ipv6")
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([active, sortOrder])
  @@map("name_servers")
}

model MailAccount {
  id           String      @id @default(cuid())
  domainId     String      @map("domain_id")
  accountId    String?     @map("account_id")
  username     String
  passwordHash String      @map("password_hash")
  quotaMb      Int         @default(1024) @map("quota_mb")
  enabled      Boolean     @default(true)
  createdAt    DateTime    @default(now()) @map("created_at")
  domain       Domain      @relation(fields: [domainId], references: [id], onDelete: Cascade)
  account      Account?    @relation(fields: [accountId], references: [id], onDelete: SetNull)
  mails        Mail[]
  aliases      MailAlias[]

  @@unique([domainId, username])
  @@index([accountId])
  @@map("mail_accounts")
}

model MailAlias {
  id        String       @id @default(cuid())
  accountId String?      @map("account_id")
  domainId  String       @map("domain_id")
  source    String
  target    String
  account   MailAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([domainId])
  @@map("mail_aliases")
}

model Mail {
  id          String      @id @default(cuid())
  accountId   String      @map("account_id")
  messageId   String      @unique @map("message_id")
  fromAddress String      @map("from_address")
  toAddress   String      @map("to_address")
  subject     String
  folder      MailFolder  @default(INBOX)
  isRead      Boolean     @default(false) @map("is_read")
  isStarred   Boolean     @default(false) @map("is_starred")
  receivedAt  DateTime    @map("received_at")
  account     MailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, folder])
  @@index([receivedAt])
  @@map("mails")
}

model Deployment {
  id                    String                    @id @default(cuid())
  domainId              String?                   @map("domain_id")
  accountId             String?                   @map("account_id")
  name                  String
  slug                  String                    @unique
  framework             DeploymentFramework
  runtime               DeploymentRuntime?
  sourceProvider        DeploymentSourceProvider  @default(MANUAL) @map("source_provider")
  repoUrl               String?                   @map("repo_url")
  gitUrl                String?                   @map("git_url")
  githubOwner           String?                   @map("github_owner")
  githubRepo            String?                   @map("github_repo")
  githubRepoId          String?                   @map("github_repo_id")
  githubVisibility      String?                   @map("github_visibility")
  branch                String                    @default("main")
  commitSha             String?                   @map("commit_sha")
  rootDirectory         String                    @default(".") @map("root_directory")
  rootPath              String                    @map("root_path")
  packageManager        DeploymentPackageManager? @map("package_manager")
  installCommand        String?                   @map("install_command")
  buildCommand          String?                   @map("build_command")
  startCommand          String?                   @map("start_command")
  outputDirectory       String?                   @map("output_directory")
  publicDirectory       String?                   @map("public_directory")
  runtimeVersion        String?                   @map("runtime_version")
  processManager        DeploymentProcessManager? @map("process_manager")
  status                DeploymentStatus          @default(STOPPED)
  healthStatus          DeploymentHealthStatus    @default(UNKNOWN) @map("health_status")
  healthUrl             String?                   @map("health_url")
  lastHealthCheckAt     DateTime?                 @map("last_health_check_at")
  lastDeployAt          DateTime?                 @map("last_deploy_at")
  port                  Int
  envVars               Json                      @default("{}") @map("env_vars")
  dbType                DatabaseType?             @map("db_type")
  dbName                String?                   @map("db_name")
  dbUser                String?                   @map("db_user")
  dbPasswordSecretRef   String?                   @map("db_password_secret_ref")
  dbConnectionSecretRef String?                   @map("db_connection_secret_ref")
  persistentPaths       Json                      @default("[]") @map("persistent_paths")
  autoDeployEnabled     Boolean                   @default(false) @map("auto_deploy_enabled")
  webhookSecretHash     String?                   @map("webhook_secret_hash")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")
  domain                Domain?                   @relation(fields: [domainId], references: [id], onDelete: SetNull)
  account               Account?                  @relation(fields: [accountId], references: [id], onDelete: SetNull)
  domainBindings        DeploymentDomain[]
  env                   DeploymentEnvVar[]
  releases              DeploymentRelease[]
  logs                  DeploymentLog[]
  doctorApprovals       DeploymentDoctorApproval[]

  @@index([domainId])
  @@index([accountId])
  @@index([status])
  @@index([sourceProvider])
  @@index([githubOwner, githubRepo])
  @@map("deployments")
}

model DeploymentDoctorApproval {
  id           String                         @id @default(cuid())
  deploymentId String                         @map("deployment_id")
  actionKey    String                         @map("action_key")
  label        String
  command      String
  reason       String
  status       DeploymentDoctorApprovalStatus @default(PENDING)
  result       Json                           @default("{}")
  requestedAt  DateTime                       @default(now()) @map("requested_at")
  decidedAt    DateTime?                      @map("decided_at")
  executedAt   DateTime?                      @map("executed_at")
  deployment   Deployment                     @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@index([deploymentId, status, requestedAt])
  @@map("deployment_doctor_approvals")
}

model DeploymentDomain {
  id           String     @id @default(cuid())
  deploymentId String     @map("deployment_id")
  domainId     String?    @map("domain_id")
  subdomainId  String?    @map("subdomain_id")
  role         String     @default("alias")
  createdAt    DateTime   @default(now()) @map("created_at")
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  domain       Domain?    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  subdomain    Subdomain? @relation(fields: [subdomainId], references: [id], onDelete: Cascade)

  @@unique([deploymentId, domainId])
  @@unique([deploymentId, subdomainId])
  @@index([domainId])
  @@index([subdomainId])
  @@map("deployment_domains")
}

model DeploymentEnvVar {
  id           String     @id @default(cuid())
  deploymentId String     @map("deployment_id")
  key          String
  value        String?
  secretRef    String?    @map("secret_ref")
  isSecret     Boolean    @default(false) @map("is_secret")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)

  @@unique([deploymentId, key])
  @@index([key])
  @@map("deployment_env_vars")
}

model DeploymentRelease {
  id              String                  @id @default(cuid())
  deploymentId    String                  @map("deployment_id")
  status          DeploymentReleaseStatus @default(QUEUED)
  commitSha       String?                 @map("commit_sha")
  commitMessage   String?                 @map("commit_message")
  commitAuthor    String?                 @map("commit_author")
  sourcePath      String?                 @map("source_path")
  artifactPath    String?                 @map("artifact_path")
  envSnapshot     Json                    @default("{}") @map("env_snapshot")
  processConfig   Json                    @default("{}") @map("process_config")
  nginxConfigPath String?                 @map("nginx_config_path")
  startedAt       DateTime?               @map("started_at")
  finishedAt      DateTime?               @map("finished_at")
  durationMs      Int?                    @map("duration_ms")
  createdAt       DateTime                @default(now()) @map("created_at")
  deployment      Deployment              @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  logs            DeploymentLog[]

  @@index([deploymentId, createdAt])
  @@index([status])
  @@map("deployment_releases")
}

model DeploymentLog {
  id           String             @id @default(cuid())
  deploymentId String             @map("deployment_id")
  releaseId    String?            @map("release_id")
  step         DeploymentStep
  level        String             @default("info")
  message      String
  stdout       String?
  stderr       String?
  metadata     Json               @default("{}")
  createdAt    DateTime           @default(now()) @map("created_at")
  deployment   Deployment         @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  release      DeploymentRelease? @relation(fields: [releaseId], references: [id], onDelete: SetNull)

  @@index([deploymentId, createdAt])
  @@index([releaseId, step])
  @@map("deployment_logs")
}

model GitHubConnection {
  id             String    @id @default("superadmin")
  username       String?
  tokenSecretRef String?   @map("token_secret_ref")
  installationId String?   @map("installation_id")
  scopes         String[]  @default([])
  connectedAt    DateTime? @map("connected_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("github_connections")
}

model Secret {
  id             String     @id @default(cuid())
  ref            String     @unique
  kind           SecretKind @default(GENERIC)
  label          String?
  encryptedValue String     @map("encrypted_value")
  metadata       Json       @default("{}")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@index([kind])
  @@map("secrets")
}

model WhmMigration {
  id             String             @id @default(cuid())
  name           String
  host           String
  port           Int                @default(2087)
  username       String
  tokenSecretRef String             @map("token_secret_ref")
  verifySsl      Boolean            @default(true) @map("verify_ssl")
  status         WhmMigrationStatus @default(DRAFT)
  serverInfo     Json               @default("{}") @map("server_info")
  summary        Json               @default("{}")
  lastScanAt     DateTime?          @map("last_scan_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  items          WhmMigrationItem[]
  tasks          WhmMigrationTask[]

  @@index([status, updatedAt])
  @@map("whm_migrations")
}

model WhmMigrationItem {
  id            String                 @id @default(cuid())
  migrationId   String                 @map("migration_id")
  type          WhmMigrationItemType
  sourceId      String                 @map("source_id")
  sourceAccount String?                @map("source_account")
  name          String
  status        WhmMigrationItemStatus @default(DISCOVERED)
  targetType    String?                @map("target_type")
  targetId      String?                @map("target_id")
  warnings      String[]               @default([])
  data          Json                   @default("{}")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  migration     WhmMigration           @relation(fields: [migrationId], references: [id], onDelete: Cascade)

  @@unique([migrationId, type, sourceId])
  @@index([migrationId, type, status])
  @@index([sourceAccount])
  @@map("whm_migration_items")
}

model WhmMigrationTask {
  id          String                 @id @default(cuid())
  migrationId String                 @map("migration_id")
  type        WhmMigrationTaskType
  account     String?
  domain      String?
  status      WhmMigrationItemStatus @default(QUEUED)
  command     String?
  result      Json                   @default("{}")
  log         String?
  approvedAt  DateTime?              @map("approved_at")
  startedAt   DateTime?              @map("started_at")
  finishedAt  DateTime?              @map("finished_at")
  createdAt   DateTime               @default(now()) @map("created_at")
  updatedAt   DateTime               @updatedAt @map("updated_at")
  migration   WhmMigration           @relation(fields: [migrationId], references: [id], onDelete: Cascade)

  @@index([migrationId, type, status])
  @@map("whm_migration_tasks")
}

model PanelBackup {
  id          String            @id @default(cuid())
  label       String
  status      PanelBackupStatus @default(QUEUED)
  archivePath String?           @map("archive_path")
  sizeBytes   Int?              @map("size_bytes")
  includes    String[]          @default([])
  result      Json              @default("{}")
  createdAt   DateTime          @default(now()) @map("created_at")
  startedAt   DateTime?         @map("started_at")
  finishedAt  DateTime?         @map("finished_at")

  @@index([status, createdAt])
  @@map("panel_backups")
}

model AuditLog {
  id          String      @id @default(cuid())
  actor       String      @default("superadmin")
  action      AuditAction
  resource    String
  resourceId  String?     @map("resource_id")
  description String?
  metadata    Json        @default("{}")
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([resource, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model GuardianIncident {
  id         String                 @id @default(cuid())
  fingerprint String               @unique
  category   String
  title      String
  detail     String
  severity   GuardianSeverity      @default(WARNING)
  status     GuardianIncidentStatus @default(OPEN)
  firstSeenAt DateTime             @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime             @default(now()) @map("last_seen_at")
  resolvedAt  DateTime?            @map("resolved_at")
  metadata    Json                 @default("{}")
  actions     GuardianAction[]

  @@index([status, lastSeenAt])
  @@index([category, lastSeenAt])
  @@map("guardian_incidents")
}

model GuardianAction {
  id          String               @id @default(cuid())
  incidentId  String?              @map("incident_id")
  action      String
  target      String
  status      GuardianActionStatus
  reason      String?
  result      Json                 @default("{}")
  retryCount  Int                  @default(0) @map("retry_count")
  createdAt   DateTime             @default(now()) @map("created_at")
  incident    GuardianIncident?    @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@index([action, target, createdAt])
  @@index([status, createdAt])
  @@map("guardian_actions")
}

model GuardianIpAllowlist {
  id        String   @id @default(cuid())
  cidr      String   @unique
  label     String?
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("guardian_ip_allowlist")
}

model GuardianIpBlock {
  id        String              @id @default(cuid())
  ip        String
  reason    String
  score     Int                 @default(0)
  status    GuardianBlockStatus @default(ACTIVE)
  expiresAt DateTime?           @map("expires_at")
  result    Json                @default("{}")
  createdAt DateTime            @default(now()) @map("created_at")
  removedAt DateTime?           @map("removed_at")

  @@index([ip, status])
  @@index([status, expiresAt])
  @@map("guardian_ip_blocks")
}

model GuardianFileFinding {
  id          String                    @id @default(cuid())
  fingerprint String                    @unique
  path        String
  reason      String
  risk        GuardianSeverity          @default(WARNING)
  status      GuardianFileFindingStatus @default(OPEN)
  sizeBytes   Int                       @default(0) @map("size_bytes")
  mode        String?
  owner       String?
  modifiedAt  DateTime?                 @map("modified_at")
  firstSeenAt DateTime                  @default(now()) @map("first_seen_at")
  lastSeenAt  DateTime                  @default(now()) @map("last_seen_at")
  metadata    Json                      @default("{}")

  @@index([status, risk, lastSeenAt])
  @@map("guardian_file_findings")
}

model GuardianNotification {
  id        String   @id @default(cuid())
  level     GuardianSeverity @default(INFO)
  title     String
  message   String
  read      Boolean  @default(false)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([read, createdAt])
  @@map("guardian_notifications")
}

model GuardianSetting {
  key       String   @id
  value     Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("guardian_settings")
}

model FirewallRule {
  id        String            @id @default(cuid())
  port      Int
  protocol  String            @default("tcp")
  direction FirewallDirection @default(IN)
  action    FirewallAction
  sourceIp  String?           @map("source_ip")
  note      String?
  createdAt DateTime          @default(now()) @map("created_at")

  @@index([port, protocol])
  @@map("firewall_rules")
}

model SuperadminSecurity {
  id                  String    @id @default("superadmin")
  totpEnabled         Boolean   @default(false) @map("totp_enabled")
  totpSecretEncrypted String?   @map("totp_secret_encrypted")
  recoveryCodesHash   String[]  @default([]) @map("recovery_codes_hash")
  lastTotpAt          DateTime? @map("last_totp_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("superadmin_security")
}
