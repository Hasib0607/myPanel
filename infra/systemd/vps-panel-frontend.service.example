[Unit]
Description=VPS Panel Frontend
After=network.target

[Service]
Type=simple
User=panel
WorkingDirectory=/opt/vps-panel/frontend
EnvironmentFile=/opt/vps-panel/.env
Environment=PORT=3000
ExecStart=/usr/bin/npm run start -- -p 3000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
