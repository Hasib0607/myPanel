[Unit]
Description=VPS Panel System Agent
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/vps-panel/sysagent
EnvironmentFile=/opt/vps-panel/.env
ExecStart=/opt/vps-panel/sysagent/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 5000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
